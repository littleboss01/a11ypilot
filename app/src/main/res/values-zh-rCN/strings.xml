    <!-- Features Card -->
    <string name="whats_in_here">功能介绍</string>
    <string name="feature_screen_title">通过无障碍树读取屏幕（无截图、无 OCR）</string>
    <string name="feature_screen_body">过滤为可见/可操作节点，为 Claude 提供紧凑的逐元素视图。</string>
    <string name="feature_planning_title">多步规划循环与提示缓存</string>
    <string name="feature_planning_body">系统提示词 + 工具 schema 标记 cache_control: ephemeral。首轮后 token 大幅减少。</string>
    <string name="feature_voice_title">按键说话语音输入</string>
    <string name="feature_voice_body">按住麦克风说话，松开即可自动运行。</string>
    <string name="feature_mcp_title">局域网 HTTP MCP 服务器</string>
    <string name="feature_mcp_body">与应用内代理相同的工具接口。Bearer 令牌认证。通过 mcp-remote 桥接与 Claude Desktop 配合使用。</string>
    <string name="feature_overlay_title">悬浮进度条</string>
    <string name="feature_overlay_body">代理运行时在其他应用上显示可拖动的状态和停止按钮。</string>
    <string name="feature_tokens_title">逐轮次 token 统计</string>
    <string name="feature_tokens_body">按轮次显示输入 / 缓存读取 / 缓存创建 / 输出，方便验证缓存效果。</string>

    <!-- Privacy Card -->
    <string name="privacy_safety">隐私与安全</string>
    <string name="privacy_1">运行期间，屏幕内容（文本 + 结构）会在每轮发送到 Anthropic API。</string>
    <string name="privacy_2">密码字段在序列化前会掩码为 \u2022\u2022\u2022\u2022。</string>
    <string name="privacy_3">API 密钥和 MCP Bearer 令牌存储在 EncryptedSharedPreferences 中，绝不记录日志。</string>
    <string name="privacy_4">MCP 默认关闭。开启时绑定 0.0.0.0 \u2014 仅在受信任的 Wi-Fi 上启用。</string>
    <string name="privacy_5">代理有硬性工具调用次数上限（可配置）。可随时通过悬浮窗停止按钮取消。</string>
    <string name="privacy_6">本应用自身的包名会从 MCP 屏幕转储中排除，防止远程客户端关闭开关。</string>

