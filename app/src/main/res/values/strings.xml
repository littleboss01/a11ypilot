    <!-- Features Card -->
    <string name="whats_in_here">What\'s in here</string>
    <string name="feature_screen_title">Reads the screen via accessibility tree (no screenshots, no OCR)</string>
    <string name="feature_screen_body">Filters to visible/actionable nodes, gives Claude a compact one-line-per-element view.</string>
    <string name="feature_planning_title">Multi-step planning loop with prompt caching</string>
    <string name="feature_planning_body">System prompt + tool schemas marked cache_control: ephemeral. Big drop in tokens after turn 1.</string>
    <string name="feature_voice_title">Push-to-talk voice input</string>
    <string name="feature_voice_body">Hold the mic, speak, release \u2014 final transcript auto-runs.</string>
    <string name="feature_mcp_title">MCP server over HTTP on your LAN</string>
    <string name="feature_mcp_body">Same tool surface as the in-app agent. Bearer-token authenticated. Works with Claude Desktop via mcp-remote bridge.</string>
    <string name="feature_overlay_title">Floating progress overlay</string>
    <string name="feature_overlay_body">Draggable status + Stop button visible across other apps while the agent runs.</string>
    <string name="feature_tokens_title">Per-turn token accounting</string>
    <string name="feature_tokens_body">Input / cache_read / cache_creation / output broken out per turn so you can sanity-check caching.</string>

    <!-- Privacy Card -->
    <string name="privacy_safety">Privacy &amp; safety</string>
    <string name="privacy_1">Screen contents (text + structure) are sent to Anthropic\'s API on every turn while a run is active.</string>
    <string name="privacy_2">Password fields are masked to \u2022\u2022\u2022\u2022 before serialization.</string>
    <string name="privacy_3">API key and MCP bearer token are stored in EncryptedSharedPreferences and never logged.</string>
    <string name="privacy_4">MCP is off by default. When on, it binds 0.0.0.0 \u2014 only enable on a trusted Wi-Fi.</string>
    <string name="privacy_5">The agent has a hard cap on tool calls per run (configurable). Cancel anytime via the Stop overlay.</string>
    <string name="privacy_6">This app\'s own package is excluded from MCP screen dumps so a remote client can\'t tap the toggle off itself.</string>

